# deploy/vps/.env.example — copy to .env and fill in. NEVER commit the real .env.
#
#   # orchestration loop:
#   cp deploy/vps/.env.example /opt/orchestration/.env && chmod 600 /opt/orchestration/.env
#   # andy gateway (setup_gateway.sh seeds it for you):
#   cp deploy/vps/.env.example /opt/andy-gateway/.env  && chmod 600 /opt/andy-gateway/.env
#
# The systemd units load this via EnvironmentFile=. Secrets live here and nowhere
# else in the repo. `.env` is gitignored. Every value below is a PLACEHOLDER.

# ============================================================================
# ANDY API GATEWAY (FastAPI/uvicorn — the MMOI routing layer behind Caddy)
# ============================================================================

# Shared secret callers (CVMatch edge functions, WhatsApp bridge, etc.) present
# in the X-API-Key / Authorization header. Generate a strong one ON THE BOX:
#   openssl rand -hex 32
ANDY_API_KEY=replace-with-openssl-rand-hex-32

# LLM provider API keys — the FALLBACK path (used when a CLI errors / hits its
# cap / quota). The gateway holds these; Supabase/clients never do.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# uvicorn listen port (loopback only; Caddy proxies to it). Match GATEWAY_PORT
# passed to setup_gateway.sh (default 8000).
PORT=8000
LOG_LEVEL=info

# Optional spend / rate controls (gateway defaults shown; tune as needed).
# RATE_LIMIT_PER_MINUTE=60
# ROUTE_TASK_LIMIT_PER_MINUTE=20
# MAX_CONCURRENT_DISPATCH=5
# MAX_DAILY_TASKS=500

# ----------------------------------------------------------------------------
# CLI-DEFAULT path (future cli_providers module — see HOSTINGER guide §Migration)
# ----------------------------------------------------------------------------
# When the gateway is upgraded to PREFER the local CLIs over the HTTP API, set
# this to 1 to enable CLI routing. Until that code ships, leave it unset/0.
# MMOI_PREFER_CLI=0
#
# Claude Code headless OAuth token, generated ON THIS BOX via `claude setup-token`
# (Pro/Max plan). Do NOT copy a token from another machine — that is a ToS
# violation. Leave blank to use ANTHROPIC_API_KEY only.
# CLAUDE_CODE_OAUTH_TOKEN=
#
# Codex + Antigravity cache their own creds in the mmoi user's home/keyring after
# `codex login` / `agy login`; no token env var is needed here for them.

# ============================================================================
# ORCHESTRATION LOOP (task router / resume-queue watchdog) — see setup.sh
# ============================================================================

# Seconds between each routing pass run by the loop (default 300 = 5 min).
ROUTER_INTERVAL=300

# Absolute path to the checked-out orchestration repo on the VPS.
APP_DIR=/opt/orchestration

# Python interpreter for the loop (setup.sh creates this venv).
PYTHON_BIN=/opt/orchestration/.venv/bin/python
