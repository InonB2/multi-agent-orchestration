# deploy/vps/.env.example — copy to .env and fill in. NEVER commit the real .env.
#
#   cp deploy/vps/.env.example /opt/orchestration/.env
#   chmod 600 /opt/orchestration/.env
#
# The systemd unit loads this file via EnvironmentFile=. Secrets live here and
# nowhere else in the repo. `.env` is gitignored.

# --- Provider API keys (only set the ones you use) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Loop tuning ---
# Seconds between each routing pass run by the loop (default 300 = 5 min).
ROUTER_INTERVAL=300

# Absolute path to the checked-out repo on the VPS.
APP_DIR=/opt/orchestration

# Python interpreter to use (the setup script creates a venv here).
PYTHON_BIN=/opt/orchestration/.venv/bin/python
